{
  "version": 2,
  "builds": [
    {
      "src": "live_app/**",
      "use": "@vercel/static"
    },
    {
      "src": "data/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/live_app/index.html"
    },
    {
      "src": "/live_app/(.*)",
      "dest": "/live_app/$1"
    },
    {
      "src": "/data/(.*)",
      "dest": "/data/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/live_app/$1"
    }
  ]
}
